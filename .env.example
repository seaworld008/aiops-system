AIOPS_ENVIRONMENT=development
AIOPS_HTTP_ADDR=:8080
AIOPS_SHUTDOWN_TIMEOUT=10s
AIOPS_WEBHOOK_HMAC_SECRET=replace-with-vault-injected-secret
AIOPS_WEBHOOK_HMAC_SECRETS_JSON={"integration-uuid/alertmanager":"replace-with-vault-injected-secret"}
# Runtime and test DSNs stay empty in the committed example. The local wrapper
# derives three in-memory test DSNs from external 0600 Secret/key files and never
# prints or persists them. AIOPS_TEST_POSTGRES_DSN is test-admin/control only;
# migrations and application admission use their separately named DSNs.
AIOPS_DATABASE_URL=
AIOPS_TEST_POSTGRES_DSN=
AIOPS_TEST_POSTGRES_MIGRATION_DSN=
AIOPS_TEST_POSTGRES_APPLICATION_DSN=
# Set this only in the workstation environment to the external local deployment.
AIOPS_LOCAL_POSTGRES_ROOT=
AIOPS_LOCAL_POSTGRES_DOCKER_CONTEXT=colima-aiops
AIOPS_LOCAL_POSTGRES_CONTAINER=aiops-postgres18
AIOPS_LOCAL_POSTGRES_HOST=localhost
AIOPS_LOCAL_POSTGRES_PORT=55432
AIOPS_LOCAL_POSTGRES_DATABASE=aiops_test
AIOPS_LOCAL_POSTGRES_ADMIN_USER=aiops
AIOPS_LOCAL_POSTGRES_MIGRATION_USER=aiops_migrator
AIOPS_LOCAL_POSTGRES_APPLICATION_USER=aiops_control_plane_workload
# Optional path overrides; blank means the root-relative layout documented in
# docs/operations/local-postgresql-development.md.
AIOPS_LOCAL_POSTGRES_ADMIN_PASSWORD_FILE=
AIOPS_LOCAL_POSTGRES_MIGRATION_PASSWORD_FILE=
AIOPS_LOCAL_POSTGRES_APPLICATION_PASSWORD_FILE=
AIOPS_LOCAL_POSTGRES_CA_FILE=
AIOPS_LOCAL_POSTGRES_ADMIN_CERT_FILE=
AIOPS_LOCAL_POSTGRES_ADMIN_KEY_FILE=
AIOPS_LOCAL_POSTGRES_MIGRATION_CERT_FILE=
AIOPS_LOCAL_POSTGRES_MIGRATION_KEY_FILE=
AIOPS_LOCAL_POSTGRES_APPLICATION_CERT_FILE=
AIOPS_LOCAL_POSTGRES_APPLICATION_KEY_FILE=
AIOPS_OIDC_ISSUER=https://keycloak.example.com/realms/aiops
AIOPS_OIDC_CLIENT_ID=aiops-control-plane
AIOPS_OIDC_MAX_SESSION_AGE=12h
AIOPS_OIDC_RECENT_AUTH_WINDOW=5m
AIOPS_WRITE_EXECUTION_MODE=disabled
AIOPS_RUNNER_GATEWAY_ADDR=:8443
# In Kubernetes, point these at regular app-owned 0400 files staged in a read-only memory volume.
AIOPS_RUNNER_GATEWAY_SERVER_CERT_FILE=/var/run/aiops/runner-gateway-identity/server-chain.pem
AIOPS_RUNNER_GATEWAY_SERVER_KEY_FILE=/var/run/aiops/runner-gateway-identity/server-key.pem
AIOPS_RUNNER_GATEWAY_READ_CLIENT_CA_FILE=/var/run/aiops/runner-gateway-identity/read-client-roots.pem
AIOPS_RUNNER_GATEWAY_WRITE_CLIENT_CA_FILE=/var/run/aiops/runner-gateway-identity/write-client-roots.pem
AIOPS_CREDENTIAL_PROTECTION_KEYRING_FILE=/var/run/aiops/runner-gateway-identity/credential-keyring.json
AIOPS_RUNNER_TRUST_DOMAIN=aiops.example.internal
